# CRA Tax Helper — Local Environment Configuration
#
# Copy this file to .env and fill in the values below.
# The start-local scripts do this for you automatically.
#
# IMPORTANT: Never commit your .env file to git — it contains your encryption key.

# ── Encryption key (required for secure data storage) ─────────────────────────
# Generate a key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Then paste the result below.
FIELD_ENCRYPTION_KEY=

# ── Local user display name (optional) ───────────────────────────────────────
# This name appears in the top-right of the app.
LOCAL_USER_NAME=Local User
LOCAL_USER_EMAIL=local@cra-helper.local
