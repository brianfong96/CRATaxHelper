# CRA Tax Helper — PRODUCTION secrets
#
# This file is only needed for deploying to aether-data.net via deploy.ps1.
# LOCAL mode needs NO .env file at all — just run: docker compose up
#
# Usage:
#   1. Copy this file to .env  (it is gitignored)
#   2. Fill in the values below
#   3. Run: .\scripts\deploy.ps1
#
# NEVER commit .env to git.

# ── Required for production ───────────────────────────────────────────────────

# Fernet encryption key — encrypts all form data at rest in Archive.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# SESSION_SECRET is read automatically from ../../Aether/.env by deploy.ps1.
# Only set it here if you want to override that source.
# SESSION_SECRET=

# ── Optional production overrides ────────────────────────────────────────────

# Restrict access to specific email addresses (comma-separated).
# Leave empty to allow any authenticated Aether user.
# ALLOWED_EMAILS=you@example.com,colleague@example.com
